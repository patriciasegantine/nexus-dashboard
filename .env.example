# --- Local development (Docker) ---
# DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus_dashboard"

# --- Cloud (Neon / Supabase / Railway) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
# Optional aliases commonly injected by platforms (Vercel Postgres, etc.)
# POSTGRES_URL_NON_POOLING="postgres://..."
# POSTGRES_PRISMA_URL="postgres://..."
# POSTGRES_URL="postgres://..."

# Auth.js
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_GOOGLE_ID="replace-with-google-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-client-secret"

# Set this in production (example: https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Email webhook (required to send welcome emails)
EMAIL_WEBHOOK_URL="http://localhost:3000/api/webhooks/email"
# Optional bearer token used in Authorization header
EMAIL_WEBHOOK_TOKEN=""

# Resend provider configuration (used by /api/webhooks/email)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
EMAIL_FROM="Nexus Dashboard <no-reply@yourdomain.com>"
# Optional: if set, sends welcome emails using a published Resend template.
RESEND_WELCOME_TEMPLATE_ID=""
SUPPORT_EMAIL="support@yourdomain.com"
EMAIL_LOGO_URL="https://yourdomain.com/logo.png"
